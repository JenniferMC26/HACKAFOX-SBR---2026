# Copiar a `.env` y rellenar con valores reales. Nunca commitear `.env`.

GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
FIREBASE_DATABASE_URL=https://paso-default-rtdb.firebaseio.com
GOOGLE_CLOUD_PROJECT=paso

# Bucket de Storage del proyecto (verificar en Firebase Console → Storage).
# Proyectos nuevos suelen ser `<projectId>.firebasestorage.app`.
STORAGE_BUCKET=paso.firebasestorage.app
