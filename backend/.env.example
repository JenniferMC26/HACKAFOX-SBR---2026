# Copiar a `.env` y rellenar. Nunca commitear `.env`.

# ── Supabase (proyecto compartido del equipo) ────────────────────────────────
SUPABASE_URL=PON TU API KEY AQUI
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Google APIs ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_CLOUD_PROJECT=paso

# ── Misc ─────────────────────────────────────────────────────────────────────
# Mientras no haya auth en el browser, SKIP_AUTH=true permite probar los
# endpoints pasando ?uid=... o el header X-Test-Uid. Nunca en producción.
SKIP_AUTH=false
