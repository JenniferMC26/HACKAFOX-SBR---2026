{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/config",             "function": "config" },
      { "source": "/routing/accessible", "function": "routingAccessible" },
      { "source": "/reports/submit",     "function": "reportSubmit" },
      { "source": "/ruta-viva/score",    "function": "rutaVivaScore" },
      { "source": "/voice/query",        "function": "voiceQuery" },
      { "source": "/crisis/start",       "function": "crisisStart" },
      { "source": "/crisis/update",      "function": "crisisUpdate" },
      { "source": "/crisis/resolve",     "function": "crisisResolve" }
    ]
  },
  "emulators": {
    "functions": { "port": 5001, "host": "0.0.0.0" },
    "hosting":   { "port": 5000, "host": "0.0.0.0" },
    "ui":        { "enabled": true, "port": 4000, "host": "0.0.0.0" },
    "singleProjectMode": true
  }
}
